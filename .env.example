# Copy this file to .env and fill in your keys. Never commit .env.

VITE_CLAUDE_API_KEY=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App Check — blocks scripts from flooding the database.
# 1. Register a reCAPTCHA v3 key at https://www.google.com/recaptcha
#    (add your domain + localhost as allowed origins)
# 2. Register the same key in Firebase console → App Check → your web app
# 3. Click "Enforce" on Firestore in App Check console
# Leave blank during local dev — App Check is skipped automatically.
VITE_RECAPTCHA_SITE_KEY=

# Support / tip jar link (Ko-fi, Buy Me a Coffee, etc.)
# Create a free Ko-fi page at https://ko-fi.com, copy your profile URL.
# When set, a "Support KickSpot" link appears on Standings (all users) and
# a share card appears in the Admin menu. Leave blank to hide all support UI.
VITE_SUPPORT_URL=
